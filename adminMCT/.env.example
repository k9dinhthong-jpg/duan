# Optional: override API proxy target for local development.
# Default in vite.config.ts points to production API domain.
# Example for running backend on your own machine:
# VITE_API_PROXY_TARGET=http://localhost:3000

VITE_API_PROXY_TARGET=https://admin.maycongtrinhnhapkhau.com.vn

# Supabase Storage config for crop + upload in Products page.
# Bucket should be a public bucket and already exist on Supabase Storage.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_BUCKET=products
